        private bool CanGo(DiGraph map, int startChamber, int endChamberint, int[] durability, int[] opensOn,
            int expeditionSize, int day)
        {
            int n = map.VertexCount;
            DiGraph<int> G = new DiGraph<int>(map.VertexCount * 2, map.Representation);
            for (int i = 0; i < n; i++)
            {
                foreach (var edgeTo in map.OutNeighbors(i))
                {
                    G.AddEdge(i + n, edgeTo, int.MaxValue);
                }

                if (opensOn[i] <= day)
                {
                    G.AddEdge(i, i + n, durability[i]);
                }
            }

            var res = Flows.FordFulkerson(G, startChamber, endChamberint + n);
            if (res.Item1 >= expeditionSize)
            {
                return true;
            }

            return false;
        }
